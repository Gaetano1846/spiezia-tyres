# ─────────────────────────────────────────────────────────────────────────────
# Firebase — Web SDK (client-side, baked into JS bundle at build time)
# ⚠ In produzione usare la VERA API key da Firebase Console → Impostazioni
#   progetto → App web. NON usare "stub-key".
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-real-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=crm-3iuocs.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=crm-3iuocs
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=crm-3iuocs.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=108478357838385108012
NEXT_PUBLIC_FIREBASE_APP_ID=your-real-app-id

# ─────────────────────────────────────────────────────────────────────────────
# Firebase — Admin SDK (server-side only, mai esposto al browser)
# Prendere dal file JSON del service account.
# ⚠ FIREBASE_ADMIN_PRIVATE_KEY: usare \n letterali (backslash-n), non a-capo reali.
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-rq14z@crm-3iuocs.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────────────────────────────────────────
# Algolia — ricerca prodotti
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=ZNZRQISP9K
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=66f570c9f29019909a358cc5fcbf91a6
NEXT_PUBLIC_ALGOLIA_INDEX=Prodotti

# ─────────────────────────────────────────────────────────────────────────────
# Reset password stateless (app Flutter magazzino, Fase M) — firma HMAC dei
# token di reset. Generare con `openssl rand -hex 32`, mai committare il valore.
# ─────────────────────────────────────────────────────────────────────────────
PASSWORD_RESET_SECRET=
